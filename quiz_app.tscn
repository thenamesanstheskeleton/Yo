corner_radius_bottom_left  = 6
corner_radius_bottom_right = 6

; ═══════════════════════════════════════════════════════
; ROOT — fills AppLayer (1280 × 660 usable area)
; ═══════════════════════════════════════════════════════
[node name="QuizApp" type="Control"]
anchors_preset  = 15
anchor_right    = 1.0
anchor_bottom   = 1.0
script = ExtResource("1_qz")

[node name="WindowBG" type="Panel" parent="."]
anchors_preset  = 15
anchor_right    = 1.0
anchor_bottom   = 1.0
theme_override_styles/panel = SubResource("SB_win_bg")

; ── Title bar ─────────────────────────────────────────
[node name="TitleBar" type="Panel" parent="."]
layout_mode = 1
anchors_preset = -1
