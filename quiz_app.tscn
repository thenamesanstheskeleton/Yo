border_color = Color(0.20, 0.20, 0.45, 1.0)
border_width_bottom = 1

[sub_resource type="StyleBoxFlat" id="SB_submit_normal"]
bg_color     = Color(0.14, 0.14, 0.30, 1.0)
border_color = Color(0.35, 0.35, 0.70, 1.0)
set_border_width_all = 2
corner_radius_top_left     = 4
corner_radius_top_right    = 4
corner_radius_bottom_left  = 4
corner_radius_bottom_right = 4

[sub_resource type="StyleBoxFlat" id="SB_submit_hover"]
