anchor_top    = 0.0
anchor_right  = 1.0
anchor_bottom = 0.0
offset_bottom = 34
grow_horizontal = 2
theme_override_styles/panel = SubResource("SB_title")

[node name="TitleLabel" type="Label" parent="TitleBar"]
