[sub_resource type="StyleBoxFlat" id="SB_alphys_panel"]
bg_color     = Color(0.06, 0.08, 0.14, 0.97)
border_color = Color(0.40, 0.60, 0.90, 1.0)
set_border_width_all = 2
corner_radius_top_left     = 6
