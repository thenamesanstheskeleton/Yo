[sub_resource type="StyleBoxEmpty" id="SBE_blank"]

[sub_resource type="Animation" id="Anim_blink"]
resource_name = "Blink"
length = 0.9
loop_mode = 1
tracks/0/type = "value"
tracks/0/imported = false
tracks/0/enabled = true
tracks/0/path = NodePath(".:modulate")
tracks/0/interp = 0
tracks/0/loop_wrap = true
tracks/0/keys = {
"times": PackedFloat32Array(0, 0.45, 0.9),
"transitions": PackedFloat32Array(1, 1, 1),
"update": 0,
"values": [Color(1, 1, 1, 1), Color(1, 1, 1, 0), Color(1, 1, 1, 1)]
}

[sub_resource type="AnimationLibrary" id="AL_cursor"]
_data = { "Blink": SubResource("Anim_blink") }

[sub_resource type="Animation" id="Anim_fade_in"]
resource_name = "FadeIn"
