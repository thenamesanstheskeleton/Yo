[gd_scene format=3 uid="uid://bonedows_main_v2"]

[ext_resource type="Script" path="res://scripts/bonedows/bonedows.gd"  id="1_bd"]
[ext_resource type="FontFile" path="res://assets/fonts/DTM-Sans.otf"   id="2_font"]
[ext_resource type="FontFile" path="res://assets/fonts/DTM-Mono.otf"   id="3_mono"]

; ── Scrollbar theme (used by all ScrollContainers in apps) ──
[sub_resource type="StyleBoxFlat" id="SB_scroll_bg"]
bg_color = Color(0.08, 0.08, 0.14, 1.0)

[sub_resource type="StyleBoxFlat" id="SB_scroll_thumb"]
bg_color     = Color(0.45, 0.45, 0.75, 1.0)
corner_radius_top_left     = 4
corner_radius_top_right    = 4
corner_radius_bottom_left  = 4
corner_radius_bottom_right = 4

[sub_resource type="StyleBoxFlat" id="SB_scroll_thumb_hover"]
bg_color     = Color(0.65, 0.65, 1.0, 1.0)
corner_radius_top_left     = 4
corner_radius_top_right    = 4
corner_radius_bottom_left  = 4
corner_radius_bottom_right = 4

[sub_resource type="Theme" id="Theme_Bonedows"]
VScrollBar/styles/scroll            = SubResource("SB_scroll_bg")
VScrollBar/styles/grabber           = SubResource("SB_scroll_thumb")
VScrollBar/styles/grabber_highlight = SubResource("SB_scroll_thumb_hover")
VScrollBar/styles/grabber_pressed   = SubResource("SB_scroll_thumb_hover")

; ── Panel styles ──────────────────────────────────────
[sub_resource type="StyleBoxFlat" id="SB_topbar"]
bg_color     = Color(0.06, 0.06, 0.14, 0.96)
border_color = Color(0.18, 0.18, 0.35, 1.0)
border_width_bottom = 1

[sub_resource type="StyleBoxFlat" id="SB_taskbar"]
bg_color     = Color(0.05, 0.05, 0.12, 0.96)
border_color = Color(0.18, 0.18, 0.35, 1.0)
border_width_top = 1

[sub_resource type="StyleBoxFlat" id="SB_exit_normal"]
bg_color = Color(0.55, 0.10, 0.10, 1.0)
corner_radius_top_left     = 3
corner_radius_top_right    = 3
corner_radius_bottom_left  = 3
corner_radius_bottom_right = 3

[sub_resource type="StyleBoxFlat" id="SB_exit_hover"]
bg_color = Color(0.85, 0.15, 0.15, 1.0)
corner_radius_top_left     = 3
corner_radius_top_right    = 3
corner_radius_bottom_left  = 3
corner_radius_bottom_right = 3

; ═══════════════════════════════════════════════════════
; ROOT  1280 × 720
; ═══════════════════════════════════════════════════════
[node name="Bonedows" type="Control"]
anchors_preset  = 15
anchor_right    = 1.0
anchor_bottom   = 1.0
grow_horizontal = 2
grow_vertical   = 2
theme  = SubResource("Theme_Bonedows")
script = ExtResource("1_bd")
mouse_filter = 0

; ── Wallpaper ─────────────────────────────────────────
[node name="Wallpaper" type="TextureRect" parent="."]
anchors_preset  = 15
anchor_right    = 1.0
anchor_bottom   = 1.0
expand_mode     = 1
stretch_mode    = 6
mouse_filter    = 2

; ── Boot screen ───────────────────────────────────────
[node name="BootScreen" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right   = 1.0
anchor_bottom  = 1.0
color = Color(0.0, 0.0, 0.0, 1.0)
mouse_filter = 0

[node name="BootLabel" type="RichTextLabel" parent="BootScreen"]
layout_mode     = 1
anchors_preset  = -1
anchor_left     = 0.06
anchor_top      = 0.12
anchor_right    = 0.94
anchor_bottom   = 0.88
grow_horizontal = 2
grow_vertical   = 2
bbcode_enabled  = true
scroll_active   = false
theme_override_font_sizes/normal_font_size = 18
theme_override_colors/default_color = Color(0.2, 0.9, 0.2, 1.0)
theme_override_fonts/normal_font    = ExtResource("3_mono")
mouse_filter = 2

; ═══════════════════════════════════════════════════════
; TOP BAR  1280 × 28px
; ═══════════════════════════════════════════════════════
[node name="TopBar" type="Panel" parent="."]
