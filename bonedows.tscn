anchor_top      = 0.0
anchor_right    = 1.0
anchor_bottom   = 0.0
offset_bottom   = 28
grow_horizontal = 2
theme_override_styles/panel = SubResource("SB_topbar")
mouse_filter = 0

[node name="OSLabel" type="Label" parent="TopBar"]
layout_mode = 0
position = Vector2(8, 4)
size     = Vector2(200, 20)
text     = "🦴 BONEDOWS"
theme_override_font_sizes/font_size  = 14
theme_override_colors/font_color     = Color(1.0, 1.0, 1.0, 1.0)
theme_override_fonts/font = ExtResource("2_font")
mouse_filter = 2

[node name="ClockLabel" type="Label" parent="TopBar"]
